# Copy this file to .env and fill in your values

# ===== LOCAL MODEL SETTINGS (FREE) =====
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2

# ===== OPTIONAL: CLOUD PROVIDERS =====
# Uncomment and add keys if you want to compare with cloud models
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ===== LANGSMITH (OPTIONAL) =====
# Free tier available for monitoring and debugging
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=agentic-ai-learning

# ===== SEARCH TOOLS (FREE) =====
# No API key needed for DuckDuckGo
# SERPER_API_KEY=your-serper-key (optional, paid alternative)
