#!/bin/sh
#
# Conventional Commits Validation Hook
# This hook validates commit messages against the Conventional Commits specification
#

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Valid commit types
types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Regex pattern for conventional commits
# Format: type(scope): subject
pattern="^($types)(\([a-z0-9\-]+\))?!?: .+$"

# Check if commit message matches pattern
if ! echo "$commit_msg" | grep -qE "$pattern"; then
    echo "${RED}âťŚ COMMIT REJECTED${NC}"
    echo ""
    echo "${YELLOW}Commit message does not follow Conventional Commits format!${NC}"
    echo ""
    echo "Expected format: ${GREEN}<type>(<scope>): <subject>${NC}"
    echo ""
    echo "Your message:"
    echo "  ${RED}$commit_msg${NC}"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo ""
    echo "Examples:"
    echo "  ${GREEN}feat(agent): add search functionality${NC}"
    echo "  ${GREEN}fix(rag): resolve memory leak${NC}"
    echo "  ${GREEN}docs: update installation guide${NC}"
    echo ""
    echo "See docs/git_conventions.md for more information"
    echo ""
    exit 1
fi

# Additional validations
first_line=$(echo "$commit_msg" | head -n 1)

# Check if type is lowercase
if echo "$first_line" | grep -qE "^[A-Z]"; then
    echo "${RED}âťŚ COMMIT REJECTED${NC}"
    echo ""
    echo "${YELLOW}Type must be lowercase${NC}"
    echo "Change: ${RED}Feat${NC} â†’ ${GREEN}feat${NC}"
    echo ""
    exit 1
fi

# Check subject length (should be <= 72 chars for first line)
length=${#first_line}
if [ "$length" -gt 72 ]; then
    echo "${YELLOW}âš ď¸Ź  WARNING: Subject line is $length characters (recommended max: 72)${NC}"
    echo "Consider shortening your commit message"
fi

# Check for period at end of subject
if echo "$first_line" | grep -qE "\.$"; then
    echo "${RED}âťŚ COMMIT REJECTED${NC}"
    echo ""
    echo "${YELLOW}Subject should not end with a period${NC}"
    echo ""
    exit 1
fi

# Check for common mistakes (past tense)
if echo "$first_line" | grep -qE ": (added|fixed|changed|updated|removed|deleted)"; then
    echo "${RED}âťŚ COMMIT REJECTED${NC}"
    echo ""
    echo "${YELLOW}Use imperative mood (present tense)${NC}"
    echo "Examples:"
    echo "  ${RED}added${NC} â†’ ${GREEN}add${NC}"
    echo "  ${RED}fixed${NC} â†’ ${GREEN}fix${NC}"
    echo "  ${RED}changed${NC} â†’ ${GREEN}change${NC}"
    echo ""
    exit 1
fi

# Success
echo "${GREEN}âś… Commit message validated${NC}"
exit 0
